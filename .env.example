# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cognigrid
POSTGRES_USER=cognigrid
POSTGRES_PASSWORD=change_me

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_AUTH=neo4j/change_me
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me
MINIO_URL=http://minio:9000
MINIO_BUCKET=cognigrid-files

# ── JWT / Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=change_me_use_long_random_string
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Services ports ───────────────────────────────────────────────────────────
GATEWAY_PORT=8080
INGESTION_PORT=8001
GRAPH_PORT=8002
AI_ENGINE_PORT=8003
GRAPHRAG_PORT=8004
AGENT_PORT=8005
FRONTEND_PORT=5173

# ── LLM ──────────────────────────────────────────────────────────────────────
# Free tier: get a key at https://console.groq.com → API Keys (starts with gsk_)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
# FH-chatbot: OpenAI-compatible endpoint (GPT-OSS 120B)
FH_API_KEY=
FH_BASE_URL=
FH_MODEL=openai-gpt-oss-120b
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=CogniGrid AI
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# URLs the BROWSER uses to reach each service. For a remote/VM deployment, set
# these to the VM host, e.g. http://10.26.5.71:8080 (NOT localhost).
VITE_GATEWAY_URL=http://localhost:8080
VITE_GRAPH_URL=http://localhost:8002
VITE_INGESTION_URL=http://localhost:8001
VITE_RAG_URL=http://localhost:8004
VITE_AGENT_URL=http://localhost:8005
VITE_RUNNER_URL=http://localhost:8006
VITE_AI_ENGINE_URL=http://localhost:8003
